# MongoDB
MONGO_URL=mongodb://localhost:27018
MONGO_DB=tamasha

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=tamasha-assets
R2_ENDPOINT_URL=

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@tamasha.app
SMTP_TLS=true

# Backblaze B2
B2_ENDPOINT_URL=
B2_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET=

# Wasabi
WASABI_ENDPOINT_URL=
WASABI_ACCESS_KEY=
WASABI_SECRET_KEY=
WASABI_BUCKET=
WASABI_REGION=us-east-1

# AWS Glacier
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_GLACIER_BUCKET=

# App
APP_BASE_URL=https://tamasha.app
ENVIRONMENT=development
LOG_LEVEL=INFO
