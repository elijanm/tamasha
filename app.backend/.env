# ─── Database ──────────────────────────────────────────────────────────────────
MONGO_URL=mongodb://localhost:27018
MONGO_DB=tamasha

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Celery ────────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ─── JWT / Auth ────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=change_me_generate_a_secure_random_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── Cloudflare R2 ─────────────────────────────────────────────────────────────

R2_ACCOUNT_ID=e01efa29c5dd4549b5a456decd653323
R2_ACCESS_KEY_ID=2dd566df7956842a22384917d4d3600c
R2_SECRET_ACCESS_KEY=fe00eaedd51f532a3a14f1b1bf020cb89531fea544bdbdcc231670a8dcfa577d
R2_BUCKET=tamasha-assets
R2_ENDPOINT_URL=https://e01efa29c5dd4549b5a456decd653323.r2.cloudflarestorage.com

# ─── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","http://10.0.0.83:5173"]

# ─── Application ───────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO

# ─── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
